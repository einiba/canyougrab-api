{
  "openapi": "3.1.0",
  "info": {
    "version": "5.0.0",
    "title": "CanYouGrab API"
  },
  "servers": [
    {
      "url": "https://api.canyougrab.it"
    }
  ],
  "paths": {
    "/api/check/bulk": {
      "post": {
        "summary": "Bulk Domain Availability Check",
        "description": "Check availability of multiple domain names in a single request. Maximum 100 domains per request. Returns results synchronously.",
        "operationId": "bulk-domain-check",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["domains"],
                "properties": {
                  "domains": {
                    "type": "array",
                    "items": { "type": "string" },
                    "maxItems": 100,
                    "description": "Array of domain names to check (max 100)",
                    "example": ["example.com", "startup.io", "myapp.dev"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Domain availability results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "domain": { "type": "string" },
                          "available": { "type": ["boolean", "null"] },
                          "tld": { "type": "string" },
                          "error": { "type": "string" }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "results": [
                    { "domain": "example.com", "available": false, "tld": "com" },
                    { "domain": "startup.io", "available": true }
                  ]
                }
              }
            }
          },
          "400": { "description": "Invalid request (empty array or exceeds 100 domains)" },
          "401": { "description": "Missing or invalid API key" },
          "429": { "description": "Rate limit or quota exceeded" }
        },
        "security": [{ "apiKey": [] }]
      }
    },
    "/api/account/usage": {
      "get": {
        "summary": "Get Usage Summary",
        "description": "Returns the current billing period usage summary for the authenticated API consumer, including lookups used and remaining quota.",
        "operationId": "get-usage",
        "responses": {
          "200": { "description": "Usage summary for the authenticated consumer" },
          "401": { "description": "Missing or invalid API key" }
        },
        "security": [{ "apiKey": [] }]
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Returns API health status. No authentication required.",
        "operationId": "health-check",
        "responses": {
          "200": { "description": "API is healthy" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as Bearer token in the Authorization header"
      }
    }
  }
}
