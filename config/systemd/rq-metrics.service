[Unit]
Description=CanYouGrab RQ Metrics Exporter (multi-environment)
After=network.target

[Service]
Type=simple
User=canyougrab
EnvironmentFile=/etc/canyougrab/env
# Watch both dev and prod queues, labeled separately
Environment=RQ_ENVIRONMENTS=dev:queue:jobs:dev,prod:queue:jobs:prod
WorkingDirectory=/opt/canyougrab/api
ExecStart=/opt/canyougrab/venv/bin/python /opt/canyougrab-repo/scripts/rq_metrics_exporter.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
