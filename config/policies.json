{
  "policies": [
    {
      "handler": {
        "export": "ApiKeyInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "allowUnauthenticatedRequests": false,
          "cacheTtlSeconds": 60
        }
      },
      "name": "api-key-inbound",
      "policyType": "api-key-inbound"
    },
    {
      "handler": {
        "export": "default",
        "module": "$import(./modules/forward-consumer-header)",
        "options": {}
      },
      "name": "forward-consumer-header",
      "policyType": "custom-code-inbound"
    },
    {
      "handler": {
        "export": "default",
        "module": "$import(./modules/monthly-quota-check)",
        "options": {}
      },
      "name": "monthly-quota-check",
      "policyType": "custom-code-inbound"
    },
    {
      "handler": {
        "export": "RateLimitInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "rateLimitBy": "function",
          "requestsAllowed": 100,
          "timeWindowMinutes": 60,
          "identifier": {
            "export": "rateLimitByPlan",
            "module": "$import(./modules/plan-rate-limit)"
          }
        }
      },
      "name": "plan-rate-limit",
      "policyType": "rate-limit-inbound"
    },
    {
      "handler": {
        "export": "OpenIdJwtInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "issuer": "https://dev-mqe5tavp6dr62e7u.us.auth0.com/",
          "audience": "https://api.canyougrab.it",
          "jwkUrl": "https://dev-mqe5tavp6dr62e7u.us.auth0.com/.well-known/jwks.json",
          "allowUnauthenticatedRequests": false
        }
      },
      "name": "open-id-jwt-auth-inbound",
      "policyType": "open-id-jwt-auth-inbound"
    }
  ]
}