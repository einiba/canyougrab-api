{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "canyougrab_queue_depth",
          "legendFormat": "Pending Jobs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "title": "Workers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "canyougrab_workers_active",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "canyougrab_workers_busy",
          "legendFormat": "Busy",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Failed Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "canyougrab_failed_jobs_total",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Queue Depth (Current)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "canyougrab_queue_depth",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 500,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "title": "Started / Scheduled Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "targets": [
        {
          "expr": "canyougrab_started_jobs",
          "legendFormat": "In Progress",
          "refId": "A"
        },
        {
          "expr": "canyougrab_scheduled_jobs",
          "legendFormat": "Scheduled (retry)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Queue Depth + Workers Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "canyougrab_queue_depth",
          "legendFormat": "Queue Depth",
          "refId": "A"
        },
        {
          "expr": "canyougrab_workers_active",
          "legendFormat": "Workers Active",
          "refId": "B"
        },
        {
          "expr": "canyougrab_workers_busy",
          "legendFormat": "Workers Busy",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Failed Jobs Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "canyougrab_failed_jobs_total",
          "legendFormat": "Total Failed",
          "refId": "A"
        },
        {
          "expr": "canyougrab_scheduled_jobs",
          "legendFormat": "Scheduled (pending retry)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Processing Time (ms)",
      "description": "Job processing time: completed_at - queued_at. Shows P50, P90, P99, and average.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "interval": "10s",
      "maxDataPoints": 2160,
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(canyougrab_processing_time_ms_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.9, rate(canyougrab_processing_time_ms_bucket[5m]))",
          "legendFormat": "P90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(canyougrab_processing_time_ms_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        },
        {
          "expr": "rate(canyougrab_processing_time_ms_sum[5m]) / rate(canyougrab_processing_time_ms_count[5m])",
          "legendFormat": "Average",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 45000 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["min", "max", "mean", "lastNotNull"] }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["canyougrab", "queue", "rq"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"],
    "time_options": ["30m", "1h", "6h", "12h", "24h", "7d", "30d", "90d"]
  },
  "timezone": "browser",
  "title": "CanYouGrab — Queue & Workers",
  "uid": "canyougrab-queue",
  "version": 1
}
