{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "CanYouGrab API"
  },
  "paths": {
    "/v1/domains/{domain}/availability": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Check Domain Availability",
        "description": "Checks whether a given domain name is available for registration based on ICANN CZDS zone file data.",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewritePattern": "${env.BASE_URL}/api/check/${params.domain}"
            }
          },
          "policies": {
            "inbound": [
              "api-key-inbound",
              "forward-consumer-header",
              "rate-limit-inbound"
            ]
          }
        },
        "operationId": "new-route-8f9d13cd"
      }
    },
    "/v1/domains/availability/bulk": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "Bulk Domain Availability Check",
        "description": "Check availability of multiple domain names in a single request. Maximum 500 domains per request.",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewritePattern": "${env.BASE_URL}/api/check/bulk"
            }
          },
          "policies": {
            "inbound": [
              "api-key-inbound",
              "forward-consumer-header",
              "rate-limit-inbound-1"
            ]
          }
        },
        "operationId": "new-route-5bccc068"
      }
    },
